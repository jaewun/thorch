# Maintainer: Thorch contributors

pkgname=thorch-waydroid-installer
pkgver=1
pkgrel=1
pkgdesc='First-boot Waydroid setup helper for Thorch'
arch=(aarch64)
license=(GPL-2.0-or-later)
depends=(bash coreutils grep kmod pacman polkit sudo systemd util-linux)
optdepends=('waydroid: Android app container installed by the helper'
            'python-pyclip: Waydroid clipboard manager support')
source=()
sha256sums=()

package() {
  cd "${startdir}/payload"
  cp -a . "${pkgdir}/"
  chmod 755 "${pkgdir}/usr/bin/thorch-install-waydroid"
  chmod 755 "${pkgdir}/usr/bin/thorch-start-waydroid"
  chmod 755 "${pkgdir}/etc/skel/Desktop/thorch-install-waydroid.desktop"
}
