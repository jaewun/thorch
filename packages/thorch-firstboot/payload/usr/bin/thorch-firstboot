#!/usr/bin/env python3
import json
import os
import subprocess
import sys
import threading

try:
    from PyQt6.QtCore import (
        QObject,
        QUrl,
        pyqtProperty as Property,
        pyqtSignal as Signal,
        pyqtSlot as Slot,
    )
    from PyQt6.QtGui import QGuiApplication
    from PyQt6.QtQml import QQmlApplicationEngine
except ImportError:
    from PySide6.QtCore import QObject, Property, QUrl, Signal, Slot
    from PySide6.QtGui import QGuiApplication
    from PySide6.QtQml import QQmlApplicationEngine


DONE_FILE = os.environ.get("THORCH_FIRSTBOOT_DONE_FILE", "/var/lib/thorch/firstboot/done")
STATE_FILE = os.environ.get("THORCH_FIRSTBOOT_STATE_FILE", "/var/lib/thorch/firstboot/state.json")
QML_FILE = os.environ.get("THORCH_FIRSTBOOT_QML", "/usr/share/thorch/firstboot/qml/Main.qml")
HELPER = os.environ.get("THORCH_FIRSTBOOT_CTL", "/usr/bin/thorch-firstbootctl")
NO_PKEXEC = os.environ.get("THORCH_FIRSTBOOT_NO_PKEXEC") == "1"
MOCK_REBOOT = os.environ.get("THORCH_FIRSTBOOT_MOCK_REBOOT") == "1"
STEAM_SETUP_CMD = os.environ.get("THORCH_FIRSTBOOT_STEAM_SETUP_CMD", "thorch-install-gaming-stack")
WAYDROID_SETUP_CMD = os.environ.get("THORCH_FIRSTBOOT_WAYDROID_SETUP_CMD", "thorch-install-waydroid --yes")


def load_state_file():
    try:
        with open(STATE_FILE, "r", encoding="utf-8") as handle:
            state = json.load(handle)
            if not isinstance(state, dict):
                return {}
    except (OSError, json.JSONDecodeError):
        return {}

    if state.get("installChoice") == "install-internal" and not state.get("phase"):
        state["phase"] = "internal-install-ready"
    return state


def has_resume_state(state):
    phase = state.get("phase", "")
    return phase in {
        "internal-install-ready",
        "internal-install-complete-remove-sd",
        "expand-sd-ready",
        "waydroid-setup-ready",
        "waydroid-setup-complete",
    }


class Backend(QObject):
    applyFinished = Signal(bool, str, str)
    wifiScanFinished = Signal(bool, str, "QVariant")
    wifiConnectFinished = Signal(bool, str)
    rebootStarted = Signal(bool, str)
    postActionStarted = Signal(bool, str)
    postActionProgress = Signal(int, str, str)
    postActionFinished = Signal(bool, str, str)
    resetFinished = Signal(bool, str)
    closeRequested = Signal()

    def __init__(self):
        super().__init__()
        self._done = os.path.exists(DONE_FILE)
        self._state = self._load_state()
        self._boot_role = self._detect_boot_role()

    def _load_state(self):
        return load_state_file()

    def _get_done(self):
        return self._done

    done = Property(bool, _get_done, constant=True)

    def _get_initial_state(self):
        return self._state

    initialState = Property("QVariant", _get_initial_state, constant=True)

    def _command_text(self, command):
        proc = subprocess.run(command, text=True, capture_output=True, check=False)
        if proc.returncode != 0:
            return ""
        return (proc.stdout or "").strip().splitlines()[0] if proc.stdout else ""

    def _base_block(self, device):
        parent = self._command_text(["lsblk", "-no", "PKNAME", device])
        if parent:
            return parent.strip()
        base = os.path.basename(device)
        if "p" in base:
            return base.rsplit("p", 1)[0]
        return base.rstrip("0123456789")

    def _block_label(self, device):
        return (
            self._command_text(["blkid", "-s", "LABEL", "-o", "value", device])
            or self._command_text(["lsblk", "-no", "LABEL", device])
        )

    def _detect_boot_role(self):
        if os.environ.get("THORCH_FIRSTBOOT_BOOT_ROLE"):
            return os.environ["THORCH_FIRSTBOOT_BOOT_ROLE"]

        root_source = self._command_text(["findmnt", "-n", "-o", "SOURCE", "/"])
        if not root_source.startswith("/dev/"):
            return "unknown"

        base = self._base_block(root_source)
        removable_path = f"/sys/class/block/{base}/removable"
        try:
            if open(removable_path, "r", encoding="utf-8").read().strip() == "1":
                return "sd"
        except OSError:
            pass

        if not base.startswith("mmcblk"):
            return "internal"

        boot_source = self._command_text(["findmnt", "-n", "-o", "SOURCE", "/boot"])
        if not boot_source.startswith("/dev/"):
            return "unknown"
        if self._base_block(boot_source) != base:
            return "unknown"
        if self._block_label(root_source) == "THORCH_ROOT" and self._block_label(boot_source) == "ROCKNIX":
            return "sd"
        return "internal"

    def _get_initial_boot_role(self):
        return self._boot_role

    initialBootRole = Property(str, _get_initial_boot_role, constant=True)

    def _run_helper(self, action, payload=None, privileged=True):
        command = [HELPER, action]
        if privileged and os.geteuid() != 0 and not NO_PKEXEC:
            command.insert(0, "pkexec")
        try:
            proc = subprocess.run(
                command,
                input=payload,
                text=True,
                capture_output=True,
                check=False,
            )
        except FileNotFoundError as exc:
            return False, f"Missing helper: {exc}", {}
        except OSError as exc:
            return False, f"Could not start helper: {exc}", {}

        output = (proc.stdout or "").strip()
        error = (proc.stderr or "").strip()
        message = output or error or f"Setup helper exited with {proc.returncode}"
        result = {}
        text = "\n".join(part for part in (output, error) if part)

        if output:
            try:
                result = json.loads(output.splitlines()[-1])
                message = result.get("message", message)
            except json.JSONDecodeError:
                pass

        if text and "output" not in result:
            result["output"] = text

        return proc.returncode == 0, message, result

    def _run_helper_stream(self, action, privileged=True):
        command = [HELPER, action]
        if privileged and os.geteuid() != 0 and not NO_PKEXEC:
            command.insert(0, "pkexec")

        try:
            proc = subprocess.Popen(
                command,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                bufsize=1,
            )
        except FileNotFoundError as exc:
            return False, f"Missing helper: {exc}", {}
        except OSError as exc:
            return False, f"Could not start helper: {exc}", {}

        final = {}
        output_lines = []
        if proc.stdout is not None:
            for raw_line in proc.stdout:
                line = raw_line.strip()
                if not line:
                    continue
                try:
                    event = json.loads(line)
                except json.JSONDecodeError:
                    output_lines.append(line)
                    del output_lines[:-160]
                    continue

                if event.get("event") == "progress":
                    self.postActionProgress.emit(
                        int(event.get("progress", 0)),
                        event.get("message", ""),
                        event.get("output", ""),
                    )
                elif "ok" in event:
                    final = event

        rc = proc.wait()
        if not final:
            output = "\n".join(output_lines)
            return False, output or f"Setup helper exited with {rc}", {"output": output}

        ok = rc == 0 and bool(final.get("ok"))
        return ok, final.get("message", ""), final

    def _run_command(self, command):
        try:
            proc = subprocess.run(command, text=True, capture_output=True, check=False)
        except FileNotFoundError as exc:
            return False, f"Missing command: {exc}", {}
        except OSError as exc:
            return False, f"Could not start setup: {exc}", {}

        output = "\n".join(
            part for part in ((proc.stdout or "").strip(), (proc.stderr or "").strip()) if part
        )
        return proc.returncode == 0, output, {"output": output}

    @Slot("QVariant")
    def apply(self, config):
        try:
            if hasattr(config, "toVariant"):
                config = config.toVariant()
            payload = json.dumps(dict(config), separators=(",", ":"))
        except Exception as exc:
            self.applyFinished.emit(False, f"Could not read setup settings: {exc}", "")
            return

        ok, message, result = self._run_helper("apply-json", payload=payload)

        if ok:
            self._done = os.path.exists(DONE_FILE)
            self._state = self._load_state()
            self.applyFinished.emit(True, message, result.get("nextAction", ""))
        else:
            self.applyFinished.emit(False, message, "")

    @Slot()
    def scanWifi(self):
        def worker():
            ok, message, result = self._run_helper("wifi-scan-json", privileged=False)
            self.wifiScanFinished.emit(ok, message, result.get("networks", []))

        threading.Thread(target=worker, daemon=True).start()

    @Slot(str, str)
    def connectWifi(self, ssid, password):
        def worker():
            payload = json.dumps({"ssid": ssid, "password": password}, separators=(",", ":"))
            ok, message, _result = self._run_helper("wifi-connect-json", payload=payload)
            self.wifiConnectFinished.emit(ok, message)

        threading.Thread(target=worker, daemon=True).start()

    @Slot()
    def skipFirstboot(self):
        self.postActionStarted.emit(True, "Skipping first boot setup.")

        def worker():
            ok, message, result = self._run_helper("finish-json")
            self._done = os.path.exists(DONE_FILE)
            self._state = self._load_state()
            if ok:
                message = "First boot setup was skipped."
            self.postActionFinished.emit(ok, message, result.get("output", ""))
            if ok:
                self.closeRequested.emit()

        threading.Thread(target=worker, daemon=True).start()

    @Slot()
    def resetFirstboot(self):
        def worker():
            ok, message, _result = self._run_helper("reset-json")
            self._done = os.path.exists(DONE_FILE)
            self._state = self._load_state()
            self.resetFinished.emit(ok, message)

        threading.Thread(target=worker, daemon=True).start()

    @Slot(str)
    def launchPostAction(self, action):
        if action == "install-internal":
            helper_action = "install-internal-stream-json"
            start_message = "Installing Thorch to internal storage. This can take several minutes."
            command = None
            streaming = True
        elif action == "expand-sd":
            helper_action = "expand-sd-json"
            start_message = "Using the rest of the SD card."
            command = None
            streaming = False
        elif action == "finish-firstboot":
            helper_action = "finish-json"
            start_message = "Finishing setup."
            command = None
            streaming = False
        elif action == "finish-and-launch-steam":
            helper_action = None
            command = None
            start_message = "Finishing setup and launching Steam."
            streaming = False
        elif action == "steam-setup":
            helper_action = None
            command = [
                "/usr/bin/bash",
                "-lc",
                STEAM_SETUP_CMD,
            ]
            start_message = "Installing Steam support. This can take a while."
            streaming = False
        elif action == "waydroid-setup":
            helper_action = None
            command = [
                "/usr/bin/bash",
                "-lc",
                WAYDROID_SETUP_CMD,
            ]
            start_message = "Installing Android app support. This downloads Waydroid images and can take a while."
            streaming = False
        else:
            self.postActionStarted.emit(False, "There is nothing else to run from here.")
            return

        self.postActionStarted.emit(True, start_message)

        def worker():
            if helper_action and streaming:
                ok, message, result = self._run_helper_stream(helper_action)
            elif helper_action:
                ok, message, result = self._run_helper(helper_action)
            elif action == "finish-and-launch-steam":
                setup_command = [
                    "/usr/bin/bash",
                    "-lc",
                    STEAM_SETUP_CMD,
                ]
                ok, output, result = self._run_command(setup_command)
                if not ok:
                    message = "Steam setup failed. Review the output, connect Wi-Fi if needed, then try again."
                else:
                    ok, message, finish_result = self._run_helper("finish-json")
                    result["output"] = "\n".join(
                        part for part in (result.get("output", ""), finish_result.get("output", "")) if part
                    )

                if ok:
                    launch_command = [
                        "/usr/bin/bash",
                        "-lc",
                        os.environ.get("THORCH_FIRSTBOOT_STEAM_LAUNCH_CMD", "/usr/bin/thorch-steamos-mode start"),
                    ]
                    ok, output, start_result = self._run_command(launch_command)
                    result["output"] = "\n".join(
                        part for part in (result.get("output", ""), start_result.get("output", "")) if part
                    )
                    message = "Steam is launching." if ok else output or "Steam setup is complete, but Steam could not be started."
            else:
                ok, output, result = self._run_command(command)
                if action == "waydroid-setup":
                    if ok:
                        mark_ok, mark_message, mark_result = self._run_helper("mark-waydroid-json")
                        ok = mark_ok
                        result["output"] = "\n".join(
                            part for part in (result.get("output", ""), mark_result.get("output", "")) if part
                        )
                        message = "Android app support is installed." if mark_ok else mark_message
                    else:
                        message = "Waydroid setup failed. Review the output, connect Wi-Fi if needed, then try again."
                else:
                    message = (
                        "Steam support is installed. Steam will start after reboot."
                        if ok else
                        "Steam setup failed. Review the output, connect Wi-Fi if needed, then try again."
                    )
            self._done = os.path.exists(DONE_FILE)
            self._state = self._load_state()
            self.postActionFinished.emit(ok, message, result.get("output", ""))
            if ok and action == "finish-and-launch-steam":
                self.closeRequested.emit()

        threading.Thread(target=worker, daemon=True).start()

    @Slot()
    def reboot(self):
        if MOCK_REBOOT:
            self.rebootStarted.emit(True, "Mock reboot requested.")
            return

        command = ["/usr/bin/systemctl", "reboot"]
        if os.geteuid() != 0 and not NO_PKEXEC:
            command.insert(0, "pkexec")

        try:
            subprocess.Popen(command)
        except OSError as exc:
            self.rebootStarted.emit(False, f"Could not reboot: {exc}")
            return

        self.rebootStarted.emit(True, "Rebooting.")


def main():
    if os.path.exists(DONE_FILE) and "--force" not in sys.argv and not has_resume_state(load_state_file()):
        return 0

    if os.environ.get("QT_IM_MODULE") == "qtvirtualkeyboard":
        os.environ.pop("QT_IM_MODULE", None)
    if os.environ.get("WAYLAND_DISPLAY"):
        os.environ.setdefault("QT_QPA_PLATFORM", "wayland")
        os.environ.setdefault("XDG_SESSION_TYPE", "wayland")
    os.environ.setdefault("QT_QUICK_CONTROLS_STYLE", "org.kde.desktop")

    app = QGuiApplication(sys.argv)
    engine = QQmlApplicationEngine()
    backend = Backend()
    backend.closeRequested.connect(app.quit)
    engine.rootContext().setContextProperty("backend", backend)
    engine.load(QUrl.fromLocalFile(QML_FILE))
    if not engine.rootObjects():
        return 1
    return app.exec()


if __name__ == "__main__":
    raise SystemExit(main())
