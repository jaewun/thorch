#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-status}"

sysfs_root="${THORCH_BACKLIGHT_SYSFS_ROOT:-/sys}"
bottom="${THORCH_BACKLIGHT_BOTTOM:-${sysfs_root}/class/backlight/ae94000.dsi.0}"
top="${THORCH_BACKLIGHT_TOP:-${sysfs_root}/class/backlight/ae96000.dsi.0}"
default_step_percent="${THORCH_BACKLIGHT_STEP_PERCENT:-5}"

usage() {
  echo "usage: thorch-backlight status|set bottom|top|all value|up [target] [step%]|down [target] [step%]" >&2
  exit 2
}

read_int() {
  local path="$1"
  [[ -r "${path}" ]] || {
    echo 0
    return
  }
  tr -cd '0-9' < "${path}"
  echo
}

emit_one() {
  local name="$1" path="$2"
  [[ -d "${path}" ]] || return 0
  printf '%s %s %s\n' \
    "${name}" \
    "$(read_int "${path}/brightness")" \
    "$(read_int "${path}/max_brightness")"
}

path_for_name() {
  case "$1" in
    bottom|control|dsi1|DSI-1)
      printf '%s\n' "${bottom}"
      ;;
    top|steam|dsi2|DSI-2)
      printf '%s\n' "${top}"
      ;;
    *)
      return 1
      ;;
  esac
}

is_uint() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

is_int() {
  [[ "${1:-}" =~ ^-?[0-9]+$ ]]
}

write_value() {
  local name="$1" value="$2" path max

  path="$(path_for_name "${name}")" || usage
  [[ -d "${path}" ]] || return 0
  max="$(read_int "${path}/max_brightness")"
  is_int "${value}" || usage
  (( value < 1 )) && value=1
  (( value > max )) && value="${max}"
  printf '%s\n' "${value}" > "${path}/brightness"
}

set_target() {
  local target="$1" value="$2"

  case "${target}" in
    all)
      write_value bottom "${value}"
      write_value top "${value}"
      ;;
    *)
      write_value "${target}" "${value}"
      ;;
  esac
}

adjust_one() {
  local name="$1" direction="$2" step_percent="$3" path max current step value

  path="$(path_for_name "${name}")" || usage
  [[ -d "${path}" ]] || return 0
  max="$(read_int "${path}/max_brightness")"
  current="$(read_int "${path}/brightness")"
  step=$((max * step_percent / 100))
  (( step < 1 )) && step=1
  if [[ "${direction}" == up ]]; then
    value=$((current + step))
  else
    value=$((current - step))
  fi
  write_value "${name}" "${value}"
}

adjust_target() {
  local direction="$1" target="$2" step_percent="$3"

  is_uint "${step_percent}" || usage
  (( step_percent < 1 || step_percent > 100 )) && usage
  case "${target}" in
    all)
      adjust_one bottom "${direction}" "${step_percent}"
      adjust_one top "${direction}" "${step_percent}"
      ;;
    *)
      adjust_one "${target}" "${direction}" "${step_percent}"
      ;;
  esac
}

case "${cmd}" in
  status)
    emit_one bottom "${bottom}"
    emit_one top "${top}"
    ;;
  set)
    [[ $# -eq 3 ]] || usage
    set_target "$2" "$3"
    ;;
  up|down)
    [[ $# -le 3 ]] || usage
    target="${2:-all}"
    step_percent="${3:-${default_step_percent}}"
    adjust_target "${cmd}" "${target}" "${step_percent}"
    ;;
  *)
    usage
    ;;
esac
