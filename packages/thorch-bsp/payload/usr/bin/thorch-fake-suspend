#!/usr/bin/env bash
set -euo pipefail

state_dir=/run/thorch-fake-suspend
active_flag="${state_dir}/active"
log_tag=thorch-fake-suspend

if [[ -r /etc/thorch/fake-suspend.conf ]]; then
  # shellcheck source=/dev/null
  source /etc/thorch/fake-suspend.conf
fi

shutdown_delay="${THORCH_FAKE_SUSPEND_SHUTDOWN_DELAY:-900}"
park_cores_enabled="${THORCH_FAKE_SUSPEND_PARK_CORES:-0}"
backlight_power="${THORCH_FAKE_SUSPEND_BACKLIGHT_POWER:-4}"

log() {
  systemd-cat -t "${log_tag}" -p info printf '%s\n' "$*" 2>/dev/null || printf '%s\n' "$*" >&2
}

thorch_user() {
  local user
  user="$(awk -F= '
    /^\[Autologin\]/ { section=1; next }
    /^\[/ { section=0 }
    section && $1 == "User" { print $2; exit }
  ' /etc/sddm.conf.d/*.conf /etc/sddm.conf 2>/dev/null || true)"
  printf '%s\n' "${user:-thorch}"
}

run_as_user() {
  local user uid home
  user="$(thorch_user)"
  home="$(getent passwd "${user}" | cut -d: -f6)"
  [[ -n "${home}" ]] || return 0
  uid="$(id -u "${user}" 2>/dev/null)" || return 0
  runuser -u "${user}" -- env \
    "HOME=${home}" \
    "XDG_RUNTIME_DIR=/run/user/${uid}" \
    "DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/${uid}/bus" \
    "$@" 2>/dev/null || true
}

save_backlights_and_blank() {
  : > "${state_dir}/backlights"
  for dev in /sys/class/backlight/*; do
    [[ -d "${dev}" ]] || continue
    local brightness blp
    brightness="$(cat "${dev}/brightness" 2>/dev/null || printf '')"
    blp="$(cat "${dev}/bl_power" 2>/dev/null || printf '')"
    printf '%s|%s|%s\n' "${dev}" "${brightness}" "${blp}" >> "${state_dir}/backlights"
    if [[ -w "${dev}/bl_power" ]]; then
      printf '%s\n' "${backlight_power}" > "${dev}/bl_power" 2>/dev/null || true
    elif [[ -w "${dev}/brightness" ]]; then
      printf '0\n' > "${dev}/brightness" 2>/dev/null || true
    fi
  done
}

restore_backlights() {
  [[ -r "${state_dir}/backlights" ]] || return 0
  while IFS='|' read -r dev brightness blp; do
    [[ -d "${dev}" ]] || continue
    if [[ -w "${dev}/bl_power" ]]; then
      # Resume should always light the panels, even if a previous run captured
      # a stale/off backlight power value.
      printf '0\n' > "${dev}/bl_power" 2>/dev/null || true
    fi
    if [[ -n "${brightness}" && -w "${dev}/brightness" ]]; then
      printf '%s\n' "${brightness}" > "${dev}/brightness" 2>/dev/null || true
    fi
    if [[ -w "${dev}/bl_power" ]]; then
      printf '0\n' > "${dev}/bl_power" 2>/dev/null || true
    fi
  done < "${state_dir}/backlights"
}

mute_audio() {
  local muted
  muted="$(run_as_user pactl get-sink-mute @DEFAULT_SINK@ | awk '{print $2}' || true)"
  printf '%s\n' "${muted:-unknown}" > "${state_dir}/audio-muted"
  run_as_user pactl set-sink-mute @DEFAULT_SINK@ true
}

restore_audio() {
  local muted
  muted="$(cat "${state_dir}/audio-muted" 2>/dev/null || printf unknown)"
  case "${muted}" in
    yes|true) run_as_user pactl set-sink-mute @DEFAULT_SINK@ true ;;
    no|false) run_as_user pactl set-sink-mute @DEFAULT_SINK@ false ;;
  esac
}

save_governors_and_powersave() {
  : > "${state_dir}/governors"
  for gov in /sys/devices/system/cpu/cpufreq/policy*/scaling_governor /sys/class/devfreq/*/governor; do
    [[ -w "${gov}" ]] || continue
    local current available
    current="$(cat "${gov}" 2>/dev/null || true)"
    printf '%s|%s\n' "${gov}" "${current}" >> "${state_dir}/governors"
    available="$(cat "${gov%/*}/scaling_available_governors" "${gov%/*}/available_governors" 2>/dev/null || true)"
    if grep -qw powersave <<< "${available}"; then
      printf 'powersave\n' > "${gov}" 2>/dev/null || true
    fi
  done
}

disable_rgb() {
  command -v thorch-rgb >/dev/null 2>&1 || return 0
  if systemctl is-active --quiet thorch-rgb-battery.service 2>/dev/null; then
    printf '1\n' > "${state_dir}/rgb-battery-service-active"
    systemctl stop thorch-rgb-battery.service >/dev/null 2>&1 || true
  fi
  thorch-rgb poweroff >/dev/null 2>&1 || true
}

restore_rgb() {
  command -v thorch-rgb >/dev/null 2>&1 || return 0
  thorch-rgb apply-config >/dev/null 2>&1 || true
  if [[ -e "${state_dir}/rgb-battery-service-active" ]]; then
    systemctl restart thorch-rgb-battery.service >/dev/null 2>&1 || true
  fi
}

restore_governors() {
  [[ -r "${state_dir}/governors" ]] || return 0
  while IFS='|' read -r gov previous; do
    [[ -n "${previous}" && -w "${gov}" ]] || continue
    printf '%s\n' "${previous}" > "${gov}" 2>/dev/null || true
  done < "${state_dir}/governors"
}

park_cores() {
  [[ "${park_cores_enabled}" == "1" ]] || return 0
  : > "${state_dir}/cores"
  for cpu in /sys/devices/system/cpu/cpu*/online; do
    [[ "${cpu}" != *"/cpu0/"* && -w "${cpu}" ]] || continue
    local online
    online="$(cat "${cpu}" 2>/dev/null || true)"
    printf '%s|%s\n' "${cpu}" "${online}" >> "${state_dir}/cores"
    printf '0\n' > "${cpu}" 2>/dev/null || true
  done
}

restore_cores() {
  [[ -r "${state_dir}/cores" ]] || return 0
  while IFS='|' read -r cpu previous; do
    [[ -w "${cpu}" ]] || continue
    printf '%s\n' "${previous:-1}" > "${cpu}" 2>/dev/null || true
  done < "${state_dir}/cores"
}

block_input() {
  command -v evtest >/dev/null 2>&1 || return 0
  : > "${state_dir}/input-grab-pids"
  for event in /dev/input/event*; do
    [[ -e "${event}" ]] || continue
    local base name
    base="${event##*/}"
    name="$(cat "/sys/class/input/${base}/device/name" 2>/dev/null || true)"
    case "${name}" in
      pmic_pwrkey|gpio-keys) continue ;;
    esac
    evtest --grab "${event}" >/dev/null 2>&1 &
    printf '%s\n' "$!" >> "${state_dir}/input-grab-pids"
  done
}

unblock_input() {
  [[ -r "${state_dir}/input-grab-pids" ]] || return 0
  while read -r pid; do
    [[ -n "${pid}" ]] || continue
    kill "${pid}" 2>/dev/null || true
  done < "${state_dir}/input-grab-pids"
}

schedule_shutdown() {
  [[ "${shutdown_delay}" =~ ^[0-9]+$ && "${shutdown_delay}" -gt 0 ]] || return 0
  (
    sleep "${shutdown_delay}"
    [[ -e "${active_flag}" ]] || exit 0
    if grep -q '^Charging$' /sys/class/power_supply/*/status 2>/dev/null; then
      log "fake suspend timeout reached while charging; leaving system on"
      exit 0
    fi
    log "fake suspend timeout reached; powering off"
    systemctl poweroff
  ) >/dev/null 2>&1 </dev/null &
  printf '%s\n' "$!" > "${state_dir}/shutdown-pid"
}

cancel_shutdown() {
  local pid
  pid="$(cat "${state_dir}/shutdown-pid" 2>/dev/null || true)"
  if [[ -n "${pid}" ]]; then
    pkill -P "${pid}" 2>/dev/null || true
    kill "${pid}" 2>/dev/null || true
  fi
}

suspend_fake() {
  if [[ -e "${active_flag}" ]]; then
    return 0
  fi
  mkdir -p "${state_dir}"
  touch "${active_flag}"
  log "entering fake suspend"
  save_backlights_and_blank
  mute_audio
  disable_rgb
  save_governors_and_powersave
  park_cores
  block_input
  schedule_shutdown
}

resume_fake() {
  if [[ ! -e "${active_flag}" ]]; then
    return 0
  fi
  log "leaving fake suspend"
  cancel_shutdown
  unblock_input
  restore_cores
  restore_governors
  restore_audio
  restore_rgb
  restore_backlights
  rm -rf "${state_dir}"
}

case "${1:-toggle}" in
  suspend) suspend_fake ;;
  resume) resume_fake ;;
  toggle)
    if [[ -e "${active_flag}" ]]; then
      resume_fake
    else
      suspend_fake
    fi
    ;;
  status)
    [[ -e "${active_flag}" ]] && echo active || echo inactive
    ;;
  *)
    echo "usage: thorch-fake-suspend [toggle|suspend|resume|status]" >&2
    exit 2
    ;;
esac
