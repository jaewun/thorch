#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  pre)
    if command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]; then
      systemctl stop thorch-rgb-battery.service >/dev/null 2>&1 || true
    fi
    /usr/bin/thorch-rgb poweroff || true
    ;;
  post)
    /usr/bin/thorch-rgb apply-config || true
    if command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]; then
      systemctl try-restart thorch-rgb-battery.service >/dev/null 2>&1 || true
    fi
    ;;
esac
